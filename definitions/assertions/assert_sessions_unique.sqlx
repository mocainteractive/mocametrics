config {
  type: "assertion",
  description: "mart_sessions deve avere esattamente una riga per final_session_id. Se fallisce indica che il grain di int_session_summary è rotto.",
  tags: ["assertions", "sessions"]
}

SELECT
  final_session_id,
  COUNT(*) AS cnt
FROM ${ref("mart_sessions")}
GROUP BY final_session_id
HAVING cnt > 1
